{
  "name": "notes-panel",
  "displayName": "Simple Notes Panel",
  "description": "A simple per-workspace notepad in the bottom panel. No formatting, no folders — just a textarea that auto-saves.",
  "version": "0.1.2",
  "publisher": "roid",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/roidayan1/vscode-notes-panel"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "notes",
    "notepad",
    "scratchpad",
    "panel",
    "workspace"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "panel": [
        {
          "id": "notesPanel",
          "title": "Notes",
          "icon": "$(note)"
        }
      ]
    },
    "views": {
      "notesPanel": [
        {
          "type": "webview",
          "id": "notesPanel.notesView",
          "name": "Notes"
        }
      ]
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Notes are read-only in untrusted workspaces."
    }
  },
  "scripts": {
    "dev": "node esbuild.mjs --watch",
    "build": "node esbuild.mjs --production",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\" \"resources/**/*.{js,css}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"resources/**/*.{js,css}\"",
    "pretest": "yarn build && tsc -p src/test/tsconfig.json",
    "test": "vscode-test",
    "validate": "yarn format:check && yarn lint && yarn build && yarn test",
    "package": "vsce package --no-dependencies",
    "deploy": "vsce publish --no-dependencies",
    "deploy:ovsx": "npx ovsx publish",
    "deploy:all": "yarn deploy && yarn deploy:ovsx",
    "vscode:prepublish": "yarn build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3",
    "esbuild": "^0.25",
    "eslint": "^10",
    "prettier": "^3",
    "typescript": "^5.8",
    "typescript-eslint": "^8"
  },
  "packageManager": "yarn@4.13.0"
}
